# # Environment variables template — copy this to .env
# Contains 50+ variables:
#   - APP settings (secret key, port, environment)
#   - DATABASE_URL (PostgreSQL + asyncpg)
#   - REDIS_URL
#   - JWT secrets
#   - TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, TWILIO_PHONE_NUMBER
#   - PLIVO_AUTH_ID, PLIVO_AUTH_TOKEN
#   - DEEPGRAM_API_KEY
#   - OPENAI_API_KEY, OPENAI_MODEL
#   - ANTHROPIC_API_KEY
#   - CARTESIA_API_KEY, CARTESIA_VOICE_ID
#   - ELEVENLABS_API_KEY, ELEVENLABS_VOICE_ID
#   - S3/MinIO credentials
#   - ENCRYPTION_KEY (for PII)
